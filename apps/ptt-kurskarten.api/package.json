    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "vitest": "^4.1.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0"
  }
