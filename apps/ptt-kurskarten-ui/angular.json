{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ptt-kurskarten-ui": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/ptt-kurskarten-ui",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "public",
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": [],
            "server": "src/main.server.ts",
            "prerender": true,
            "ssr": {
              "entry": "src/server.ts"
            },
            "localize": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "12kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "static": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.static.ts"
                },
                {
                  "replace": "src/app/app.routes.ts",
                  "with": "src/app/app.routes.static.ts"
                }
              ],
              "ssr": false,
              "prerender": false,
              "assets": [
                "public",
                "src/assets",
                {
                  "glob": "places.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "place_names.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "map_anchors.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "edition_anchor_overrides.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "editions.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "services.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "service_trips.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "link_measures.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                },
                {
                  "glob": "assertions.json",
                  "input": "../ptt-kurskarten.api/data/v2",
                  "output": "assets/graph-data"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "ptt-kurskarten-ui:build:production"
            },
            "development": {
              "buildTarget": "ptt-kurskarten-ui:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json"
          }
        }
      }
    }
  }
}
